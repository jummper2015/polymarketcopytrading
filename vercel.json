{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NODE_ENV": "production",
    "SIMULATION_MODE": "paper_only"
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "functions": {
    "app/api/cron/route.ts": {
      "maxDuration": 300
    },
    "app/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron?task=runner",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron?task=scan:leaderboard",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron?task=scan:wallets",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron?task=update:rules",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron?task=report:daily",
      "schedule": "0 8 * * *"
    }
  ]
}
